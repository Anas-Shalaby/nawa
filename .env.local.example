# Supabase — use the JWT "anon public" key from Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Do NOT use sb_publishable_ for auth sign-in; keep publishable separate if needed:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only (never expose to the browser)
# Required for clinic registration (tenant insert + app_metadata.tenant_id)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signed booking ticket URLs (patient success page + cancel). Use a long random string in production.
BOOKING_TICKET_SECRET=your-booking-ticket-secret

# Dev auth — staff user must have app_metadata.tenant_id matching MOCK_TENANT_ID
SUPABASE_DEV_USER_EMAIL=secretary@clinic.example
SUPABASE_DEV_USER_PASSWORD=your-dev-password
MOCK_TENANT_ID=00000000-0000-0000-0000-000000000001
MOCK_CLINIC_WHATSAPP=+20 100 123 4567

# Super Admin (Phase 17) — founder dashboard at /super-admin
# Set your founder email OR grant app_metadata.role = "super_admin" via Admin API
SUPER_ADMIN_EMAIL=founder@nawah.example
# SUPER_ADMIN_EMAILS=founder@nawah.example,ops@nawah.example
# SUPER_ADMIN_SUBSCRIPTION_EGP=499

# CRON_SECRET=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
